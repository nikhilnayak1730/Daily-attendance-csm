            <input id="s-roll" type="text" class="inp" placeholder="e.g. 24L31A4201" autocomplete="username">
          </div>
          <div>
            <p class="lbl" style="margin-bottom:5px">Password</p>
            <div style="position:relative">
              <input id="s-pass" type="password" class="inp" placeholder="Min. 6 characters"
                     style="padding-right:38px" autocomplete="new-password">
              <button type="button" onclick="togglePwd('s-pass')"
                style="position:absolute;right:11px;top:50%;transform:translateY(-50%);
                       background:none;border:none;color:var(--t3);cursor:pointer;
                       font-size:13px;padding:3px;line-height:1;transition:color .12s"
                onmouseover="this.style.color='var(--t2)'" onmouseout="this.style.color='var(--t3)'">●</button>
            </div>
          </div>
          <div style="padding-top:3px">
            <button class="btn-full" id="s-btn" onclick="doSignup()">
              <span id="s-btxt">Create account</span>
