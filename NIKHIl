  1:[
    {s:'AP',       f:'Applied Physics',                               t:'10:00–11:30', type:'theory', c:'#60A5FA'},
    {s:'ESE',      f:'English for Skill Enhancement',                 t:'11:30–01:00', type:'theory', c:'#FBBF24'},
    {s:'ODEVC',    f:'ODE & Vector Calculus',                         t:'02:00–03:30', type:'theory', c:'#A78BFA'},
    {s:'DS',       f:'Data Structures',                                t:'03:30–05:00', type:'theory', c:'#34D399'},
  ],
  2:[
    {s:'ODEVC',    f:'ODE & Vector Calculus',                         t:'10:00–11:30', type:'theory', c:'#A78BFA'},
    {s:'ESE',      f:'English for Skill Enhancement',                 t:'11:30–01:00', type:'theory', c:'#FBBF24'},
    {s:'AP',       f:'Applied Physics',                                t:'02:00–03:30', type:'theory', c:'#60A5FA'},
    {s:'DS',       f:'Data Structures',                                t:'03:30–05:00', type:'theory', c:'#34D399'},
  ],
  3:[
    {s:'ELCSL/EW', f:'English Language Lab / Engineering Workshop',   t:'10:00–12:00', type:'lab',    c:'#22D3EE'},
    {s:'EGCAD(T)', f:'Engineering Graphics & CAD — Theory',           t:'02:00–03:00', type:'theory', c:'#F87171'},
    {s:'EGCAD(P)', f:'Engineering Graphics & CAD — Practical',        t:'03:00–05:00', type:'lab',    c:'#F87171'},
  ],
  4:[
    {s:'EGCAD(T)', f:'Engineering Graphics & CAD — Theory',           t:'10:00–11:00', type:'theory', c:'#F87171'},
    {s:'ELCSL/EW', f:'English Language Lab / Engineering Workshop',   t:'11:00–01:00', type:'lab',    c:'#22D3EE'},
    {s:'APL/DSL',  f:'Applied Physics Lab / Data Structures Lab',     t:'02:00–04:00', type:'lab',    c:'#818CF8'},
  ],
  5:[
    {s:'APL/DSL',  f:'Applied Physics Lab / Data Structures Lab',     t:'10:00–12:00', type:'lab',    c:'#818CF8'},
    {s:'PPL(T)',   f:'Python Programming Lab — Theory',                t:'02:00–03:00', type:'theory', c:'#FCD34D'},
    {s:'PPL(P)',   f:'Python Programming Lab — Practical',             t:'03:00–05:00', type:'lab',    c:'#FCD34D'},
  ],
