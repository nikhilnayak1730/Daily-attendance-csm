<!-- Toast -->
<div id="toast"><span id="toast-i"></span><span id="toast-m"></span></div>


<!-- ████████ SCRIPT ████████ -->
<script>

/* ═══════════════════════════════════════════════════════════════
   SUPABASE — replace with your actual keys
   https://supabase.com → Settings → API
   ═══════════════════════════════════════════════════════════════ */
const SB_URL = 'YOUR_SUPABASE_URL';
const SB_KEY = 'YOUR_SUPABASE_ANON_KEY';

/*
  ── ONE-TIME SQL (Supabase SQL Editor) ─────────────────────────

  CREATE TABLE IF NOT EXISTS students (
    id          UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    roll_number TEXT UNIQUE NOT NULL,
    name        TEXT DEFAULT '',
    password    TEXT NOT NULL,
    created_at  TIMESTAMPTZ DEFAULT NOW()
  );

  CREATE TABLE IF NOT EXISTS class_ratings (
    id                UUID DEFAULT gen_random_uuid() PRIMARY KEY,
    roll_number       TEXT NOT NULL,
    date              DATE NOT NULL,
    slot_index        INT  NOT NULL,
    subject           TEXT NOT NULL,
    time_slot         TEXT NOT NULL,
    attendance_stars  INT  DEFAULT 0 CHECK (attendance_stars  BETWEEN 0 AND 2),
    improvement_stars INT  DEFAULT 0 CHECK (improvement_stars BETWEEN 0 AND 3),
    notes             TEXT DEFAULT '',
    updated_at        TIMESTAMPTZ DEFAULT NOW(),
    UNIQUE(roll_number, date, slot_index)
  );

  ALTER TABLE students      ENABLE ROW LEVEL SECURITY;
  ALTER TABLE class_ratings ENABLE ROW LEVEL SECURITY;
  CREATE POLICY "s_all" ON students      FOR ALL USING (true) WITH CHECK (true);
  CREATE POLICY "r_all" ON class_ratings FOR ALL USING (true) WITH CHECK (true);

  ─────────────────────────────────────────────────────────────── */


/* ═══════════════════════════════════════════════════════════════
   TIMETABLE  —  Section-G CSE AI&ML, w.e.f 19-01-2026, Room 202
   JS day index: 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri 6=Sat
   ═══════════════════════════════════════════════════════════════ */
